@app.route('/generate_remedy_report', methods=['GET'])
def generate_remedy_report():
    remedy_text = request.args.get('remedy_text')
    from_date = request.args.get('from_date')
    to_date = request.args.get('to_date')
    completed_date = request.args.get('completed_date')
    remedy_status = request.args.get('remedy_status')
    remedy_case = request.args.get('remedy_case')
    area_id = request.args.get('area')
    picture_location = request.args.get('picture_location')

    if (from_date and to_date and completed_date) or ((not from_date or not to_date) and not completed_date):
        return jsonify({
            "error": "Please either provide From + To Dates or a Completed Date — not both."
        }), 400

    connection = get_db_connection()
    cursor = connection.cursor(dictionary=True)

    try:
        base_filters = ""
        params = []

        # Date filters (apply carefully)
        if completed_date:
            base_filters += " AND DATE(COALESCE(r.`Date Completed`, a.`Assessment Date`)) = %s"
            params.append(completed_date)
        else:
            base_filters += " AND DATE(COALESCE(r.`Task Date`, a.`Assessment Date`)) BETWEEN %s AND %s"
            params.extend([from_date, to_date])

        if area_id and area_id.lower() != "all":
            base_filters += " AND COALESCE(r.`Area ID`, a.`Area ID`) = %s"
            params.append(area_id)

        if remedy_text and remedy_text.lower() != "all":
            base_filters += " AND r.`Remedy Text` = %s"
            params.append(remedy_text)

        if remedy_status and remedy_status.lower() != "all status":
            base_filters += " AND a.`Assessment Status` = %s"
            params.append(remedy_status)

        if remedy_case and remedy_case.lower() != "all cases":
            base_filters += " AND a.`Assessment Case` = %s"
            params.append(remedy_case)

        picture_filter = ""
        if picture_location == "not_null":
            picture_filter = " AND r.`Picture Location` IS NOT NULL AND r.`Picture Location` != ''"
        elif picture_location == "null":
            picture_filter = " AND (r.`Picture Location` IS NULL OR r.`Picture Location` = '')"

        query = f"""
            -- Remedy LEFT JOIN Assessment
            SELECT 
                COALESCE(r.`Remedy ID`, 'NA') AS `Remedy ID`,
                COALESCE(r.`Area ID`, a.`Area ID`) AS `Area ID`,
                COALESCE(a.`Assessment Case`, 'Not Assessed') AS `Assessed Case`,
                COALESCE(a.`Assessment Status`, 'Not Assessed') AS `Remedy Status`,
                COALESCE(r.`Pile No`, a.`Pile No`) AS `Pile No`,
                COALESCE(r.`Table ID`, a.`Table ID`) AS `Table ID`,
                DATE_FORMAT(COALESCE(r.`Task Date`, a.`Assessment Date`), '%d %b %Y') AS `Task Date`,
                r.`Remedy Text`
            FROM remedy r
            LEFT JOIN assessment a
                ON r.`Area ID` = a.`Area ID`
               AND r.`Table ID` = a.`Table ID`
               AND r.`Pile No` = a.`Pile No`
            WHERE 1=1
            {base_filters}
            {picture_filter}

            UNION

            -- Assessment LEFT JOIN Remedy (to catch assessment-only rows)
            SELECT 
                COALESCE(r.`Remedy ID`, 'NA') AS `Remedy ID`,
                COALESCE(r.`Area ID`, a.`Area ID`) AS `Area ID`,
                COALESCE(a.`Assessment Case`, 'Not Assessed') AS `Assessed Case`,
                COALESCE(a.`Assessment Status`, 'Not Assessed') AS `Remedy Status`,
                COALESCE(r.`Pile No`, a.`Pile No`) AS `Pile No`,
                COALESCE(r.`Table ID`, a.`Table ID`) AS `Table ID`,
                DATE_FORMAT(COALESCE(r.`Task Date`, a.`Assessment Date`), '%d %b %Y') AS `Task Date`,
                r.`Remedy Text`
            FROM assessment a
            LEFT JOIN remedy r
                ON r.`Area ID` = a.`Area ID`
               AND r.`Table ID` = a.`Table ID`
               AND r.`Pile No` = a.`Pile No`
            WHERE r.`Remedy ID` IS NULL
            {base_filters}
        ORDER BY `Area ID`, `Table ID`, `Pile No`
        """

        cursor.execute(query, params * 2)  # params used in both SELECTs
        return jsonify(cursor.fetchall())

    finally:
        cursor.close()
        connection.close()





